# Copy to .env and fill in real values.
DATABASE_URL=postgresql+psycopg2://finance:finance@localhost:5432/finance_tracker
JWT_SECRET_KEY=generate-a-long-random-string
DEBUG=false

# MongoDB — AI call telemetry (optional; disabled if unreachable)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=finsight

# ------------------------------------------------------------------
# LLM provider — powers categorization of ambiguous transactions and
# the Ask AI (text-to-SQL) feature. Without any key, categorization
# runs rules-only and Ask AI returns 503; everything else works.
#
# Option A: Anthropic (default; paid, ~pennies at Haiku prices)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5

# Option B: any OpenAI-compatible endpoint. Set LLM_PROVIDER=openai
# and one of the combos below.
#
# Google Gemini — FREE tier (key from https://aistudio.google.com):
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=your-gemini-key
#   OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   OPENAI_MODEL=gemini-2.0-flash
#
# Groq — FREE tier (key from https://console.groq.com):
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=gsk_...
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   OPENAI_MODEL=llama-3.3-70b-versatile
#
# Ollama — fully local & free, no key (https://ollama.com, `ollama pull llama3.2`):
#   LLM_PROVIDER=openai
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_MODEL=llama3.2
#
# OpenAI itself (paid):
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=sk-...
#   OPENAI_MODEL=gpt-4o-mini
